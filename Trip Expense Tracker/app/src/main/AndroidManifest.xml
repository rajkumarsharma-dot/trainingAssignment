<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.tools.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_menu_today"
        android:label="@string/app_name"
        android:roundIcon="@android:drawable/ic_menu_today"
        android:supportsRtl="true"
        android:theme="@style/Theme.TripExpenseTracker"
        tools:targetApi="31">

        <!-- Splash Activity as the Launcher -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TripExpenseTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth Activity -->
        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main Dashboard Activity -->
        <activity
            android:name=".ui.dashboard.MainActivity"
            android:exported="false" />

        <!-- Trip Details Activity -->
        <activity
            android:name=".ui.trip.TripDetailsActivity"
            android:exported="false" />

        <!-- Expense Management Activity -->
        <activity
            android:name=".ui.expense.ExpenseActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Analytics Dashboard Activity -->
        <activity
            android:name=".ui.analytics.AnalyticsActivity"
            android:exported="false" />

        <!-- Firebase Messaging Service -->
        <service
            android:name=".service.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
